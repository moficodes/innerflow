{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile information for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt"]
    },
    "Session": {
      "title": "Breathing Session",
      "description": "A recorded breathing exercise or breath-hold attempt.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["exercise", "hold"] },
        "exerciseName": { "type": "string" },
        "durationSeconds": { "type": "number" },
        "breathHoldSeconds": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Records of breathing sessions and breath-holds."
    }
  }
}
